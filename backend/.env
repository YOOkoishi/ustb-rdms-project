# RDMS 后端配置
# 数据库
DATABASE_URL=sqlite+aiosqlite:///./rdms.db

# 安全
SECRET_KEY=rdms-super-secret-key-change-in-production-2024
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (逗号分隔)
CORS_ORIGINS=http://localhost:8001,http://localhost:5173,http://127.0.0.1:8001

# 文件存储: local 或 qiniu
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# 七牛云配置 (STORAGE_BACKEND=qiniu 时生效)
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=
